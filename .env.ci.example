# Скопируй в .env.ci и заполни. .env.ci в .gitignore.
# Залить пачкой:
#   gh secret set   -f .env.ci.secrets
#   gh variable set -f .env.ci.vars
#
# Этот файл — единый источник, ниже две секции по типу. Удобно
# держать вместе, в gh передавать раздельно (см. Makefile target).

# === SECRETS ===
BOT_TOKEN=
SSH_HOST=
SSH_USER=
SSH_PRIVATE_KEY=
SSH_PORT=22
DEPLOY_PATH=/home/USER/recall_bot

# === VARIABLES ===
MONGO_DB_NAME=recall_bot
LOG_LEVEL=INFO
SCHEDULER_TZ=Europe/Moscow
