# Скопируй в .env.ci и заполни. .env.ci в .gitignore.
# Залить всё пачкой:
#   make push-ci-config

# === SECRETS ===
BOT_TOKEN=
# MONGO_URI — оставь пустым если используешь хостовую mongo без auth
# (тогда хватит MONGO_HOST в variables). Если есть auth — пиши полный URI:
#   mongodb://user:pass@host:27017/?authSource=admin
MONGO_URI=
SSH_HOST=
SSH_USER=
SSH_PRIVATE_KEY=
SSH_PORT=22
DEPLOY_PATH=/home/USER/recall_bot

# === VARIABLES ===
# Хост mongo, видимый ИЗ контейнера бота.
# host.docker.internal маппится на хост через extra_hosts в docker-compose.yml.
MONGO_HOST=host.docker.internal
MONGO_PORT=27017
MONGO_DB_NAME=recall_bot
LOG_LEVEL=INFO
SCHEDULER_TZ=Europe/Moscow
